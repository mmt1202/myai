{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myai.local/schemas/agent_run_schema.json",
  "title": "Foundation Agent Run",
  "description": "Stateful agent run contract for foundation task orchestration.",
  "type": "object",
  "required": ["run_id", "task", "status", "steps", "created_at", "updated_at"],
  "properties": {
    "run_id": {"type": "string"},
    "session_id": {"type": "string"},
    "owner_id": {"type": "string"},
    "project_id": {"type": "string"},
    "task": {"type": "string"},
    "input": {"type": "array", "items": {"type": "object"}},
    "route_mode": {"type": "string"},
    "approval_policy": {"type": "string", "enum": ["never", "on_write", "on_cost", "always"]},
    "status": {"type": "string", "enum": ["queued", "running", "waiting_tool", "waiting_approval", "completed", "failed", "cancelled"]},
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step_id", "type", "status", "created_at"],
        "properties": {
          "step_id": {"type": "string"},
          "type": {"type": "string"},
          "status": {"type": "string", "enum": ["queued", "running", "waiting_tool", "waiting_approval", "completed", "failed", "cancelled"]},
          "input": {"type": "object", "additionalProperties": true},
          "output": {"type": "object", "additionalProperties": true},
          "error": {"type": "string"},
          "created_at": {"type": "string"},
          "updated_at": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "route_decision": {"type": "object", "additionalProperties": true},
    "rule_decision": {"type": "object", "additionalProperties": true},
    "usage": {"type": "object", "additionalProperties": true},
    "cost": {"type": "object", "additionalProperties": true},
    "artifacts": {"type": "object", "additionalProperties": true},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "completed_at": {"type": "string"},
    "error": {"type": "string"}
  },
  "additionalProperties": false
}

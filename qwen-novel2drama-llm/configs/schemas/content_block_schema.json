{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myai.local/schemas/content_block_schema.json",
  "title": "Foundation Content Block",
  "description": "Unified multimodal content block for foundation chat, reasoning, memory, skills, MCP and agent APIs.",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["text", "image", "video", "audio", "subtitle", "metadata", "file", "url", "tool_result", "reasoning_hint"]
    },
    "text": {"type": "string"},
    "mime_type": {"type": "string"},
    "uri": {"type": "string"},
    "file_id": {"type": "string"},
    "filename": {"type": "string"},
    "bytes": {"type": "integer", "minimum": 0},
    "sha256": {"type": "string"},
    "width": {"type": "integer", "minimum": 1},
    "height": {"type": "integer", "minimum": 1},
    "duration_ms": {"type": "integer", "minimum": 0},
    "fps": {"type": "number", "minimum": 0},
    "sample_rate": {"type": "integer", "minimum": 1},
    "channels": {"type": "integer", "minimum": 1},
    "language": {"type": "string"},
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start_ms", "end_ms"],
        "properties": {
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 0},
          "label": {"type": "string"},
          "text": {"type": "string"},
          "speaker": {"type": "string"},
          "frame_start": {"type": "integer", "minimum": 0},
          "frame_end": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "license": {"type": "string"},
        "creator": {"type": "string"},
        "created_at": {"type": "string"},
        "content_credentials": {"type": "string"},
        "watermark": {"type": "string"}
      },
      "additionalProperties": true
    },
    "safety": {
      "type": "object",
      "properties": {
        "sensitivity": {"type": "string", "enum": ["public", "internal", "confidential", "secret"]},
        "retention": {"type": "string", "enum": ["none", "session", "project", "long_term"]},
        "policy_tags": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {"properties": {"type": {"const": "text"}}},
      "then": {"required": ["text"]}
    },
    {
      "if": {"properties": {"type": {"enum": ["image", "video", "audio", "file"]}}},
      "then": {"anyOf": [{"required": ["uri"]}, {"required": ["file_id"]}]}
    },
    {
      "if": {"properties": {"type": {"const": "url"}}},
      "then": {"required": ["uri"]}
    },
    {
      "if": {"properties": {"type": {"const": "metadata"}}},
      "then": {"required": ["metadata"]}
    }
  ],
  "additionalProperties": false
}

# Production-like deployment profile. Copy this file and provide real values outside git.

FOUNDATION_AGENT_RUN_STORE=postgres
FOUNDATION_AGENT_RUN_POSTGRES_DSN=<configured outside git>
FOUNDATION_AGENT_RUN_POSTGRES_POOL_ENABLED=true
FOUNDATION_AGENT_RUN_POSTGRES_POOL_MIN=1
FOUNDATION_AGENT_RUN_POSTGRES_POOL_MAX=10
FOUNDATION_AGENT_RUN_POSTGRES_POOL_TIMEOUT=30

FOUNDATION_QUOTA_BACKEND=postgres
FOUNDATION_QUOTA_POSTGRES_DSN=<configured outside git>
FOUNDATION_WORKSPACE_QUOTA_ENABLED=true
FOUNDATION_WORKSPACE_QUOTAS=configs/auth/workspace_quotas.json
FOUNDATION_WORKSPACE_QUOTA_STATE=outputs/auth/workspace_quota_state.json

FOUNDATION_API_QUOTA_ENABLED=true
FOUNDATION_API_QUOTA_PATHS=/v1/chat,/v1/reason,/v1/multimodal/analyze,/v1/agent/run

FOUNDATION_RATE_LIMIT_ENABLED=true
FOUNDATION_RATE_LIMIT_CONFIG=configs/auth/rate_limits.json
FOUNDATION_RATE_LIMIT_STATE=outputs/auth/rate_limit_state.json

FOUNDATION_AUTH_REQUIRED=true
FOUNDATION_AUTH_KEYS=configs/auth/api_keys.json

FOUNDATION_PRIMARY_MODEL=external.openai.primary
FOUNDATION_FALLBACK_MODELS=external.anthropic.claude,external.deepseek.chat,local.qwen2_5_1_5b_instruct
FOUNDATION_MODEL_SETTINGS_STORE=outputs/model_settings/model_settings.json

OPENAI_MODEL=<configured outside git>
OPENAI_API_KEY=<configured outside git>
OPENAI_BASE_URL=https://api.openai.com/v1

MODEL_BASE_URL=<configured outside git>
MODEL_API_KEY=<configured outside git>

{
  "server_name": "local-code-agent-mcp",
  "version": "0.1.0",
  "status": "local_wrapper_implemented",
  "description": "Local MCP-style JSON-RPC tool server wrapper for the coding-agent foundation.",
  "entrypoint": "scripts/mcp_tool_server.py",
  "tool_registry": "configs/tool_registry.json",
  "permission_profiles": "configs/tool_permission_profiles.json",
  "tools": [
    {
      "name": "context.build_index",
      "registry_tool_id": "build_context_index"
    },
    {
      "name": "context.search",
      "registry_tool_id": "search_context_index"
    },
    {
      "name": "context.read_chunk",
      "registry_tool_id": "read_context_chunk"
    },
    {
      "name": "symbols.build_index",
      "registry_tool_id": "build_code_symbols"
    },
    {
      "name": "symbols.search",
      "registry_tool_id": "search_code_symbols"
    },
    {
      "name": "patch.plan",
      "registry_tool_id": "create_patch_plan"
    },
    {
      "name": "patch.validate_spec",
      "registry_tool_id": "validate_patch_spec"
    },
    {
      "name": "patch.create_diff",
      "registry_tool_id": "create_unified_diff"
    },
    {
      "name": "patch.apply_safe",
      "registry_tool_id": "apply_patch_spec"
    },
    {
      "name": "tests.run_plan",
      "registry_tool_id": "run_test_plan"
    },
    {
      "name": "agent.run",
      "registry_tool_id": "ai_code_agent"
    }
  ],
  "supported_methods": [
    "initialize",
    "ping",
    "tools/list",
    "tools/call",
    "registry/list",
    "permissions/list",
    "server/info"
  ],
  "security_policy": {
    "default_write_mode": "dry_run",
    "requires_explicit_apply_confirmation": true,
    "allowed_test_commands_only": true,
    "project_root_only": true,
    "no_model_weight_edits": true,
    "profile_based_permissions": true,
    "audit_log": "outputs/tool_logs/mcp_tool_server.jsonl"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myai.local/schemas/response_envelope_schema.json",
  "title": "Foundation Response Envelope",
  "type": "object",
  "required": ["request_id", "status"],
  "properties": {
    "request_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "status": {"type": "string", "enum": ["ok", "queued", "running", "failed", "cancelled"]},
    "model": {
      "type": "object",
      "properties": {
        "model_id": {"type": "string"},
        "provider": {"type": "string"},
        "alias": {"type": "string"},
        "route_mode": {"type": "string"},
        "fallback_used": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "usage": {
      "type": "object",
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "image_units": {"type": "number", "minimum": 0},
        "video_seconds": {"type": "number", "minimum": 0},
        "audio_seconds": {"type": "number", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "cost": {
      "type": "object",
      "properties": {
        "currency": {"type": "string"},
        "estimated": {"type": "number", "minimum": 0},
        "actual": {"type": "number", "minimum": 0},
        "cache_savings": {"type": "number", "minimum": 0}
      },
      "additionalProperties": true
    },
    "output": {},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "error": {"$ref": "error_code_schema.json"},
    "route": {
      "type": "object",
      "properties": {
        "selected_model": {"type": "string"},
        "candidates": {"type": "array", "items": {"type": "string"}},
        "fallback_chain": {"type": "array", "items": {"type": "string"}},
        "policy_hits": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
